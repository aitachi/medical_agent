  {
    "plan_id": "FP001",
    "name": "高血压稳定期年度随访计划",
    "target_condition": "原发性高血压",
    "duration_days": 365,
    "followup_frequency": "每3个月一次",
    "tasks": [
      {
        "task_id": "FT001",
        "name": "血压测量（坐位双侧上臂）",
        "type": "测量",
        "frequency": "每周2次"
      },
      {
        "task_id": "FT002",
        "name": "服药依从性问卷（MMAS-8）",
        "type": "问卷",
        "frequency": "每3个月一次"
      },
      {
        "task_id": "FT003",
        "name": "血常规、尿常规、肾功能、电解质、空腹血糖、血脂四项",
        "type": "检查",
        "frequency": "每6个月一次"
      }
    ],
    "reminders": [
      "下次随访前3天测量晨起血压并记录",
      "随访日前1周避免高盐饮食"
    ]
  },
  {
    "plan_id": "FP002",
